local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")
local RunService = game:GetService("RunService")

local DATASTORE_NAME = "Test1"
local AUTOSAVE_INTERVAL = 120
local MAX_RETRIES = 5

local dataStore = DataStoreService:GetDataStore(DATASTORE_NAME)

local savingPlayers = {}

local function waitForRequestBudget(requestType)
	while DataStoreService:GetRequestBudgetForRequestType(requestType) < 1 do
		task.wait(1)
	end
end

local function getDefaultData()
	return {
		Rolls = 0,
		Coins = 2,

		Inventory = {
			MaxInventory = 10,
			OwnediFrames = {},
			EquippediFrame = "",
		}
	}
end

local function setupLeaderstats(plr: Player)
	local leaderstats = Instance.new("Folder")
	leaderstats.Name = "leaderstats"
	leaderstats.Parent = plr

	local rolls = Instance.new("NumberValue")
	rolls.Name = "Rolls"
	rolls.Value = 0
	rolls.Parent = leaderstats

	local coins = Instance.new("NumberValue")
	coins.Name = "Coins"
	coins.Value = 2
	coins.Parent = leaderstats

	local inventory = Instance.new("Folder")
	inventory.Name = "Inventory"
	inventory.Parent = plr

	local maxInventory = Instance.new("NumberValue")
	maxInventory.Name = "MaxInventory"
	maxInventory.Value = 10
	maxInventory.Parent = inventory

	local ownediFrames = Instance.new("Folder")
	ownediFrames.Name = "OwnediFrames"
	ownediFrames.Parent = inventory

	local equippediFrame = Instance.new("StringValue")
	equippediFrame.Name = "EquippediFrame"
	equippediFrame.Value = ""
	equippediFrame.Parent = inventory

	local key = "Player_" .. plr.UserId

	local success = false
	local data = nil

	for attempt = 1, MAX_RETRIES do
		waitForRequestBudget(Enum.DataStoreRequestType.GetAsync)

		success, data = pcall(function()
			return dataStore:GetAsync(key)
		end)

		if success then
			break
		else
			warn("Load failed for " .. plr.Name .. ". Attempt " .. attempt .. "/" .. MAX_RETRIES)
			task.wait(2)
		end
	end

	if not success then
		plr:Kick("Your data failed to load. Please rejoin.")
		return
	end

	if data == nil then
		data = getDefaultData()
	end

	rolls.Value = data.Rolls or 0
	coins.Value = data.Coins or 2

	if data.Inventory then
		maxInventory.Value = data.Inventory.MaxInventory or 10
		equippediFrame.Value = data.Inventory.EquippediFrame or ""

		if data.Inventory.OwnediFrames then
			for iframeName, amount in pairs(data.Inventory.OwnediFrames) do
				local ownedValue = Instance.new("NumberValue")
				ownedValue.Name = iframeName
				ownedValue.Value = amount
				ownedValue.Parent = ownediFrames
			end
		end
	end

	print("Loaded data for " .. plr.Name)
	print(data)
end

local function buildDataTable(plr: Player)
	local leaderstats = plr:FindFirstChild("leaderstats")
	local inventory = plr:FindFirstChild("Inventory")

	if not leaderstats or not inventory then
		return nil
	end

	local rolls = leaderstats:FindFirstChild("Rolls")
	local coins = leaderstats:FindFirstChild("Coins")

	local maxInventory = inventory:FindFirstChild("MaxInventory")
	local ownediFrames = inventory:FindFirstChild("OwnediFrames")
	local equippediFrame = inventory:FindFirstChild("EquippediFrame")

	if not rolls or not coins or not maxInventory or not ownediFrames or not equippediFrame then
		return nil
	end

	local ownediFramesTable = {}

	for _, iframeValue in ipairs(ownediFrames:GetChildren()) do
		if iframeValue:IsA("NumberValue") then
			ownediFramesTable[iframeValue.Name] = iframeValue.Value
		end
	end

	return {
		Rolls = rolls.Value,
		Coins = coins.Value,

		Inventory = {
			MaxInventory = maxInventory.Value,
			OwnediFrames = ownediFramesTable,
			EquippediFrame = equippediFrame.Value,
		}
	}
end

local function save(plr: Player)
	if not plr then
		return
	end

	if savingPlayers[plr.UserId] then
		return
	end

	local dataTable = buildDataTable(plr)

	if not dataTable then
		warn("Could not build data table for " .. plr.Name)
		return
	end

	savingPlayers[plr.UserId] = true

	local key = "Player_" .. plr.UserId
	local success = false
	local err = nil

	for attempt = 1, MAX_RETRIES do
		waitForRequestBudget(Enum.DataStoreRequestType.UpdateAsync)

		success, err = pcall(function()
			dataStore:UpdateAsync(key, function(oldData)
				oldData = oldData or getDefaultData()

				oldData.Rolls = dataTable.Rolls
				oldData.Coins = dataTable.Coins

				oldData.Inventory = oldData.Inventory or {}
				oldData.Inventory.MaxInventory = dataTable.Inventory.MaxInventory
				oldData.Inventory.OwnediFrames = dataTable.Inventory.OwnediFrames
				oldData.Inventory.EquippediFrame = dataTable.Inventory.EquippediFrame

				return oldData
			end)
		end)

		if success then
			print("Saved data for " .. plr.Name)
			print(dataTable)
			break
		else
			warn("Save failed for " .. plr.Name .. ". Attempt " .. attempt .. "/" .. MAX_RETRIES)
			warn(err)
			task.wait(2)
		end
	end

	savingPlayers[plr.UserId] = nil

	if not success then
		warn("Final save failed for " .. plr.Name)
	end
end

Players.PlayerAdded:Connect(function(player)
	setupLeaderstats(player)
end)

Players.PlayerRemoving:Connect(function(player)
	save(player)
end)

game:BindToClose(function()
	local players = Players:GetPlayers()

	for _, player in ipairs(players) do
		task.spawn(function()
			save(player)
		end)
	end

	task.wait(5)
end)

task.spawn(function()
	while true do
		task.wait(AUTOSAVE_INTERVAL)

		for _, player in ipairs(Players:GetPlayers()) do
			task.spawn(function()
				save(player)
			end)
		end
	end
end)
